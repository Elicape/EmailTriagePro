# EmailTriagePro — Configuración
# Rellena con tus datos personales. Este archivo es solo plantilla.
# Copia a config.ini o usa la GUI (Configuración → Guardar y Reiniciar).

[IMAP]
host = imap.tu-servidor.com
port = 993
user = tu@email.com
pass = tu_contraseña_segura
use_ssl = true

[TELEGRAM]
token = 123456789:ABCdefGHIjkl...
chat_id = 123456789

[HORARIOS]
resumen = 09:00,14:00,19:00

[LLAMA]
llama_path = bin/llama-cli
model_path = models/Qwen3-VL-2B-Instruct-Q4_K_M.gguf

[GUI]
poll_interval = 60
temperature = 0.1
max_tokens = 256
log_disable = true
no_show_timings = true

[PERFIL]
user_id = usuario_01
user_name = Laura
